###############################################################################
# MANIFEST.in
# Archivos adicionales incluidos en el paquete distribuido
###############################################################################

# ---------------------------------------------------------------------------
# Documentación y metadatos
# ---------------------------------------------------------------------------
include README.md
include LICENSE
include ARCHITECTURE.md
include requirements.txt
include setup.py

# ---------------------------------------------------------------------------
# Backend (paquete principal)
# ---------------------------------------------------------------------------
recursive-include backend *.py
recursive-include backend py.typed

# ---------------------------------------------------------------------------
# Frontend (React / Vite)
# ---------------------------------------------------------------------------
include web/package.json
include web/package-lock.json
include web/index.html
include web/tsconfig.json
include web/tsconfig.app.json
include web/tsconfig.node.json
include web/vite.config.ts
recursive-include web/src *.ts *.tsx *.css *.d.ts

# ---------------------------------------------------------------------------
# Server (FastAPI)
# ---------------------------------------------------------------------------
recursive-include server *.py
recursive-include server py.typed
recursive-include server/api py.typed


# ---------------------------------------------------------------------------
# Excluir basura, cachés y artefactos locales
# ---------------------------------------------------------------------------
exclude *.pyc
exclude *.pyo
exclude *~
exclude *.log

recursive-exclude * __pycache__ *.pyc *.pyo
recursive-exclude *.egg-info *
recursive-exclude reports *
recursive-exclude tests *
